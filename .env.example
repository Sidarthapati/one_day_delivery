# ─────────────────────────────────────────────────────────────────────────────
# Template for the shared cloud test env. Copy to .env and fill in real values.
#   cp .env.example .env      # then edit .env (which is gitignored)
# Load before running the app: set -a && source .env && set +a
# ─────────────────────────────────────────────────────────────────────────────

# ── Postgres (Render) ────────────────────────────────────────────────────────
export SPRING_DATASOURCE_URL="jdbc:postgresql://<render-host>:5432/<db-name>?sslmode=require"
export SPRING_DATASOURCE_USERNAME="oneday"
export SPRING_DATASOURCE_PASSWORD="<render-db-password>"

# ── RabbitMQ (CloudAMQP) ─────────────────────────────────────────────────────
# Full AMQP URL from the CloudAMQP instance page. amqps:// → TLS (5671); /<vhost> is required.
# Leave CLOUDAMQP_URL unset to use a local Docker broker (amqp://guest:guest@localhost:5672).
export SPRING_PROFILES_ACTIVE="dev"
export CLOUDAMQP_URL="amqps://<user>:<pass>@<host>.rmq.cloudamqp.com/<vhost>"
